{
	"name": "goboard",
	"version": "1.0.0",
	"description": "Render Go game diagrams from Markdown code blocks.",
	"main": "build/main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node -e \"require('fs').copyFileSync('plugin-dist/manifest.json', 'manifest.json')\"",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"update-baseline": "npx jest --config jest.baseline.config.js",
		"update-docs": "npx jest --config jest.docs.config.js",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint src/**/*.ts --fix"
	},
	"keywords": [],
	"author": "Dmitry I. Sokolov",
	"license": "MIT",
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.8.0",
		"builtin-modules": "^5.2.0",
		"esbuild": "^0.28.0",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"obsidian": "^1.12.3",
		"sharp": "^0.34.5",
		"ts-jest": "^29.4.9",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.3"
	},
	"dependencies": {
		"i18next": "^26.2.0"
	}
}
